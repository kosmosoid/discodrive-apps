<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- All Files Access: the sync folder lives at /sdcard/DiscoDrive so it stays visible
         in file managers and survives uninstall (a deliberate, user-facing synced folder,
         mirroring the desktop app). The app is sideloaded via GitHub Releases, not Play
         Store, so Play's MANAGE_EXTERNAL_STORAGE policy does not apply. If this ever ships
         on Play, migrate to scoped storage (getExternalFilesDir / SAF) to drop this. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"/>
    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:localeConfig="@xml/locales_config"
        android:theme="@style/Theme.DiscoDrive">
        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="org.discodrive.android.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>
    </application>
</manifest>
